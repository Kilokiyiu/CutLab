{
  "name": "tv-anime-standard",
  "description": "标准电视动画命名与归档模板",
  "namingRule": {
    "template": "EP{EP:02}_S{SC:02}_C{CUT:03}_{TYPE}",
    "separator": "_",
    "typeSuffixes": {
      "storyboard": "分镜",
      "keyframe": "原画",
      "inbetween": "动画",
      "background": "背景",
      "render": "渲染"
    }
  },
  "archiveTemplate": {
    "pathPattern": "{EP:02}/S{SC:02}/C{CUT:03}/{TYPE}/",
    "folders": ["分镜", "原画", "动画", "背景", "渲染"]
  },
  "recognitionPatterns": [
    "{N}卡{TYPE}",
    "EP{EP}_S{SC}_C{CUT}_{TYPE}",
    "第{N}卡"
  ]
}
