<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Panel chrome -->
    <Style Selector="Border.side-panel">
        <Setter Property="Background" Value="#3C3F41"/>
        <Setter Property="BorderBrush" Value="#555555"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

    <Style Selector="Border.workspace-panel">
        <Setter Property="Background" Value="#2B2B2B"/>
        <Setter Property="BorderBrush" Value="#555555"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="Border.preview-panel">
        <Setter Property="Background" Value="#3C3F41"/>
        <Setter Property="BorderBrush" Value="#555555"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
    </Style>

    <Style Selector="Border.section-header">
        <Setter Property="Background" Value="#484848"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="BorderBrush" Value="#555555"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style Selector="Border.section-header TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
    </Style>

    <Style Selector="Border.panel-title">
        <Setter Property="Background" Value="#484848"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="BorderBrush" Value="#555555"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style Selector="Border.panel-title TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#DDDDDD"/>
    </Style>

    <Style Selector="Border.toolbar">
        <Setter Property="Background" Value="#3C3F41"/>
        <Setter Property="BorderBrush" Value="#555555"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <Style Selector="Border.status-bar">
        <Setter Property="Background" Value="#252525"/>
        <Setter Property="BorderBrush" Value="#555555"/>
        <Setter Property="BorderThickness" Value="1,1,0,0"/>
        <Setter Property="Padding" Value="10,4"/>
    </Style>

    <Style Selector="Border.status-bar TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#AAAAAA"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.toolbar-separator">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Background" Value="#555555"/>
        <Setter Property="Margin" Value="6,2"/>
    </Style>

    <Style Selector="Button.toolbar-btn">
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="2,0"/>
    </Style>

    <Style Selector="Button.toolbar-btn.primary">
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="#555555"/>
    </Style>

    <Style Selector="Menu">
        <Setter Property="Background" Value="#3C3F41"/>
        <Setter Property="Foreground" Value="#DDDDDD"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Height" Value="28"/>
    </Style>

    <Style Selector="ListBox.shot-list">
        <Setter Property="Background" Value="#2B2B2B"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="ListBox.shot-list ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox.shot-list ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#4A5568"/>
    </Style>

    <Style Selector="ListBox.shot-list ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#383838"/>
    </Style>

</Styles>
