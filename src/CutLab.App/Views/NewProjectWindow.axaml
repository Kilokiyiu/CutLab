<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CutLab.App.ViewModels"
        x:Class="CutLab.App.Views.NewProjectWindow"
        x:DataType="vm:NewProjectViewModel"
        Title="新建项目"
        Width="640"
        Height="680"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="*,Auto" Margin="24">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <TextBlock Text="新建项目" FontSize="22" FontWeight="Bold"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="规则模板"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding AvailableTemplates}"
                                  SelectedItem="{Binding SelectedTemplate}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1"
                                Content="应用模板"
                                Command="{Binding ApplySelectedTemplateCommand}"/>
                    </Grid>
                    <TextBlock Opacity="0.6"
                               FontSize="12"
                               Text="{Binding SelectedTemplate.Description}"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="项目名称"/>
                    <TextBox Text="{Binding Name}"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="集数 (EP)"/>
                    <NumericUpDown Value="{Binding Episode}" Minimum="1" Maximum="999"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="素材文件夹"/>
                    <TextBox Text="{Binding SourcePath}" IsReadOnly="True"/>
                    <TextBlock Opacity="0.6" FontSize="12" Text="在下一步通过浏览选择文件夹"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="归档根路径"/>
                    <TextBox Text="{Binding RootPath}"/>
                    <TextBlock Opacity="0.6" FontSize="12" Text="默认取素材文件夹的上一级目录"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="命名模板"/>
                    <TextBox Text="{Binding NamingTemplate}"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="归档路径模板"/>
                    <TextBox Text="{Binding ArchivePathPattern}"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="归档子目录（逗号分隔）"/>
                    <TextBox Text="{Binding ArchiveFoldersText}"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="类型后缀（逗号分隔）"/>
                    <TextBox Text="{Binding TypeSuffixesText}"/>
                    <TextBlock Opacity="0.6"
                               FontSize="12"
                               Text="顺序：分镜, 原画, 动画, 背景, 渲染"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="识别规则（每行一条）"/>
                    <TextBox Text="{Binding RecognitionPatternsText}"
                             AcceptsReturn="True"
                             MinHeight="72"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button Content="取消" IsCancel="True" Click="CancelButton_OnClick"/>
            <Button Content="浏览文件夹..." Click="BrowseButton_OnClick"/>
            <Button Content="创建" IsDefault="True" Click="CreateButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
