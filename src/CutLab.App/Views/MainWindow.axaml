<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CutLab.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="820"
        x:Class="CutLab.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="CutLab"
        Width="1280" Height="820">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="24">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,4">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="{Binding Subtitle}" Opacity="0.7"/>
            </StackPanel>
            <ComboBox Grid.Column="1"
                      Width="260"
                      Margin="8,0,0,0"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding RecentProjects}"
                      SelectedItem="{Binding SelectedProject}"
                      PlaceholderText="选择项目"/>
            <Button Grid.Column="2"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Content="新建项目"
                    Command="{Binding NewProjectCommand}"/>
            <Button Grid.Column="3"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Content="刷新"
                    Command="{Binding RefreshProjectsCommand}"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,16,0,8">
            <TextBox Grid.Column="0"
                     PlaceholderText="输入或选择待扫描文件夹路径"
                     Text="{Binding SourcePath}"/>
            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    Content="浏览..."
                    Command="{Binding PickFolderCommand}"/>
            <CheckBox Grid.Column="2"
                      Margin="8,0,0,0"
                      Content="含子目录"
                      VerticalAlignment="Center"
                      IsChecked="{Binding ScanRecursive}"/>
            <Button Grid.Column="3"
                    Margin="8,0,0,0"
                    Content="扫描"
                    Command="{Binding ScanCommand}"/>
        </Grid>

        <WrapPanel Grid.Row="2" Margin="0,0,0,8">
            <Button Content="项目设置" Margin="0,0,8,8" Command="{Binding OpenSettingsCommand}"/>
            <Button Content="执行重命名" Margin="0,0,8,8" Command="{Binding ExecuteRenameCommand}"/>
            <Button Content="创建归档目录" Margin="0,0,8,8" Command="{Binding CreateArchiveDirectoriesCommand}"/>
            <Button Content="移动到归档" Margin="0,0,8,8" Command="{Binding MoveToArchiveCommand}"/>
            <Button Content="缺卡检测" Margin="0,0,8,8" Command="{Binding DetectMissingCutsCommand}"/>
            <Button Content="导出 Excel" Margin="0,0,8,8" Command="{Binding ExportCutListCommand}"/>
            <Button Content="导出进度台账" Margin="0,0,8,8" Command="{Binding ExportProgressReportCommand}"/>
            <Button Content="生成预览视频" Margin="0,0,8,8" Command="{Binding GeneratePreviewVideoCommand}"/>
            <Button Content="撤销上次" Margin="0,0,8,8" Command="{Binding UndoCommand}"/>
        </WrapPanel>

        <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="0,0,0,12">
            <TextBlock Grid.Column="0" Text="插卡位置" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <NumericUpDown Grid.Column="1"
                           Width="90"
                           Minimum="1"
                           Maximum="999"
                           Value="{Binding InsertAfterCut}"/>
            <TextBlock Grid.Column="2" Text="资产类型" VerticalAlignment="Center" Margin="12,0,8,0"/>
            <ComboBox Grid.Column="3"
                      Width="120"
                      ItemsSource="{Binding AvailableAssetTypes}"
                      SelectedItem="{Binding InsertAssetType}"/>
            <CheckBox Grid.Column="4"
                      Margin="12,0,0,0"
                      Content="仅未识别文件"
                      VerticalAlignment="Center"
                      IsChecked="{Binding InsertUnrecognizedOnly}"/>
            <Button Grid.Column="6"
                    Margin="8,0,0,0"
                    Content="插卡重命名"
                    Command="{Binding InsertCutCommand}"/>
            <TextBox Grid.Column="5"
                     Margin="16,0,8,0"
                     PlaceholderText="版本标签筛选 (v1/draft/s)"
                     Text="{Binding VersionTagFilter}"/>
            <Button Grid.Column="7"
                    Content="筛选"
                    Command="{Binding ApplyVersionFilterCommand}"/>
        </Grid>

        <Grid Grid.Row="4" ColumnDefinitions="*,300">
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding PreviewItems}"
                      SelectedItem="{Binding SelectedPreviewRow}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="卡号" Binding="{Binding CutId}" Width="*"/>
                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="2*"/>
                    <DataGridTextColumn Header="目标" Binding="{Binding Target}" Width="2*"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="*"/>
                    <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="12"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <TextBlock Grid.Row="0"
                               Text="卡号预览"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding PreviewCaption}"
                               TextWrapping="Wrap"
                               Opacity="0.85"
                               Margin="0,0,0,8"/>
                    <Image Grid.Row="2"
                           Source="{Binding PreviewImage}"
                           Stretch="Uniform"
                           MaxHeight="320"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    <ScrollViewer Grid.Row="3"
                                  Margin="0,12,0,0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  MaxHeight="96">
                        <ItemsControl ItemsSource="{Binding CutGallery}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CutGalleryItemViewModel">
                                    <Button Padding="4"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectGalleryCutCommand}"
                                            CommandParameter="{Binding CutId}">
                                        <StackPanel Width="72" Spacing="4">
                                            <Image Source="{Binding Thumbnail}"
                                                   Width="64"
                                                   Height="64"
                                                   Stretch="Uniform"/>
                                            <TextBlock Text="{Binding CutId}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="5"
                   Margin="0,12,0,0"
                   Text="{Binding MissingCutsSummary}"
                   TextWrapping="Wrap"
                   FontWeight="SemiBold"/>

        <TextBlock Grid.Row="6"
                   Margin="0,8,0,0"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Opacity="0.85"/>
    </Grid>
</Window>
