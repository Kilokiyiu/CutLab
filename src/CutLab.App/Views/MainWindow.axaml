<Window xmlns="https://github.com/avaloniaui"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:vm="using:CutLab.App.ViewModels"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"

        x:Class="CutLab.App.Views.MainWindow"

        x:DataType="vm:MainWindowViewModel"

        Icon="/Assets/avalonia-logo.ico"

        Title="CutLab — 镜头卡号生产管理"

        Width="1400" Height="900"

        Background="#2B2B2B">



    <Design.DataContext>

        <vm:MainWindowViewModel/>

    </Design.DataContext>



    <Grid RowDefinitions="Auto,Auto,*,Auto">



        <!-- Menu bar -->

        <Menu Grid.Row="0">

            <MenuItem Header="文件">

                <MenuItem Header="浏览文件夹..." Command="{Binding PickFolderCommand}"/>

                <MenuItem Header="扫描" Command="{Binding ScanCommand}"/>

                <Separator/>

                <MenuItem Header="导出 Excel" Command="{Binding ExportCutListCommand}"/>

                <MenuItem Header="导出进度台账" Command="{Binding ExportProgressReportCommand}"/>

                <MenuItem Header="导出缺卡清单..." Command="{Binding ExportMissingCutsCommand}"/>

            </MenuItem>

            <MenuItem Header="项目">

                <MenuItem Header="新建项目" Command="{Binding NewProjectCommand}"/>

                <MenuItem Header="刷新项目列表" Command="{Binding RefreshProjectsCommand}"/>

                <Separator/>

                <MenuItem Header="项目设置..." Command="{Binding OpenSettingsCommand}"/>

                <Separator/>

                <MenuItem Header="导出项目配置..." Command="{Binding ExportProjectConfigCommand}"/>

                <MenuItem Header="导入项目配置..." Command="{Binding ImportProjectConfigCommand}"/>

                <Separator/>

                <MenuItem Header="删除当前项目..." Command="{Binding DeleteProjectCommand}"/>

            </MenuItem>

            <MenuItem Header="操作">

                <MenuItem Header="执行重命名" Command="{Binding ExecuteRenameCommand}"/>

                <MenuItem Header="插卡重命名" Command="{Binding InsertCutCommand}"/>

                <MenuItem Header="自动编号（未识别）" Command="{Binding BatchAutoNumberCommand}"/>

                <Separator/>

                <MenuItem Header="创建归档目录" Command="{Binding CreateArchiveDirectoriesCommand}"/>

                <MenuItem Header="移动到归档" Command="{Binding MoveToArchiveCommand}"/>

                <Separator/>

                <MenuItem Header="缺卡检测" Command="{Binding DetectMissingCutsCommand}"/>

                <MenuItem Header="生成预览视频" Command="{Binding GeneratePreviewVideoCommand}"/>

                <Separator/>

                <MenuItem Header="撤销上次操作" Command="{Binding UndoCommand}"/>

            </MenuItem>

        </Menu>



        <!-- Toolbar -->

        <Border Grid.Row="1" Classes="toolbar">

            <ScrollViewer HorizontalScrollBarVisibility="Auto"

                          VerticalScrollBarVisibility="Disabled">

                <StackPanel Orientation="Horizontal" Spacing="2">

                    <ComboBox Width="220"

                              Margin="4,0,0,0"

                              VerticalAlignment="Center"

                              ItemsSource="{Binding RecentProjects}"

                              SelectedItem="{Binding SelectedProject}"

                              PlaceholderText="选择项目"/>

                    <Button Classes="toolbar-btn" Content="新建" Command="{Binding NewProjectCommand}"/>

                    <Button Classes="toolbar-btn" Content="刷新" Command="{Binding RefreshProjectsCommand}"/>

                    <Border Classes="toolbar-separator"/>

                    <Button Classes="toolbar-btn primary" Content="扫描" Command="{Binding ScanCommand}"/>

                    <Button Classes="toolbar-btn" Content="重命名" Command="{Binding ExecuteRenameCommand}"/>

                    <Button Classes="toolbar-btn" Content="插卡" Command="{Binding InsertCutCommand}"/>

                    <Button Classes="toolbar-btn primary" Content="自动编号" Command="{Binding BatchAutoNumberCommand}"/>

                    <Border Classes="toolbar-separator"/>

                    <Button Classes="toolbar-btn" Content="建归档" Command="{Binding CreateArchiveDirectoriesCommand}"/>

                    <Button Classes="toolbar-btn" Content="移归档" Command="{Binding MoveToArchiveCommand}"/>

                    <Button Classes="toolbar-btn" Content="缺卡" Command="{Binding DetectMissingCutsCommand}"/>

                    <Border Classes="toolbar-separator"/>

                    <Button Classes="toolbar-btn" Content="Excel" Command="{Binding ExportCutListCommand}"/>

                    <Button Classes="toolbar-btn" Content="台账" Command="{Binding ExportProgressReportCommand}"/>

                    <Button Classes="toolbar-btn" Content="预览视频" Command="{Binding GeneratePreviewVideoCommand}"/>

                    <Border Classes="toolbar-separator"/>

                    <Button Classes="toolbar-btn" Content="撤销" Command="{Binding UndoCommand}"/>

                    <Button Classes="toolbar-btn" Content="设置" Command="{Binding OpenSettingsCommand}"/>

                </StackPanel>

            </ScrollViewer>

        </Border>



        <!-- Main workspace -->

        <Grid Grid.Row="2" ColumnDefinitions="280,Auto,*,Auto,360">



            <!-- Left sidebar: scan & insert settings -->

            <Border Grid.Column="0" Classes="side-panel">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel Spacing="0">

                        <Border Classes="section-header">

                            <TextBlock Text="扫描"/>

                        </Border>

                        <StackPanel Margin="12,10" Spacing="8">

                            <TextBox PlaceholderText="源文件夹路径"

                                     Text="{Binding SourcePath}"

                                     TextWrapping="Wrap"

                                     MinHeight="32"/>

                            <Grid ColumnDefinitions="*,Auto">

                                <Button Grid.Column="0"

                                        Classes="toolbar-btn"

                                        HorizontalAlignment="Stretch"

                                        Content="浏览..."

                                        Command="{Binding PickFolderCommand}"/>

                                <Button Grid.Column="1"

                                        Classes="toolbar-btn primary"

                                        Margin="6,0,0,0"

                                        Content="扫描"

                                        Command="{Binding ScanCommand}"/>

                            </Grid>

                            <CheckBox Content="含子目录"

                                      IsChecked="{Binding ScanRecursive}"/>

                            <CheckBox Content="仅预览（不执行重命名/归档）"

                                      IsChecked="{Binding DryRunOnly}"/>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">

                                <TextBlock Grid.Column="0"

                                           Text="冲突策略"

                                           VerticalAlignment="Center"

                                           Opacity="0.75"

                                           FontSize="12"/>

                                <ComboBox Grid.Column="1"

                                          ItemsSource="{Binding ConflictStrategyOptions}"

                                          SelectedItem="{Binding SelectedConflictStrategy}">

                                    <ComboBox.ItemTemplate>

                                        <DataTemplate>

                                            <TextBlock Text="{Binding Label}"/>

                                        </DataTemplate>

                                    </ComboBox.ItemTemplate>

                                </ComboBox>

                            </Grid>

                        </StackPanel>



                        <Border Classes="section-header">

                            <TextBlock Text="编号 / 插卡"/>

                        </Border>

                        <StackPanel Margin="12,10" Spacing="8">

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">

                                <TextBlock Grid.Column="0"

                                           Text="起始卡号"

                                           VerticalAlignment="Center"

                                           Opacity="0.75"

                                           FontSize="12"/>

                                <NumericUpDown Grid.Column="1"

                                               Minimum="1"

                                               Maximum="999"

                                               Value="{Binding InsertAfterCut}"/>

                            </Grid>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">

                                <TextBlock Grid.Column="0"

                                           Text="类型"

                                           VerticalAlignment="Center"

                                           Opacity="0.75"

                                           FontSize="12"/>

                                <ComboBox Grid.Column="1"

                                          ItemsSource="{Binding AvailableAssetTypes}"

                                          SelectedItem="{Binding InsertAssetType}"/>

                            </Grid>

                            <CheckBox Content="插卡时仅未识别文件"

                                      IsChecked="{Binding InsertUnrecognizedOnly}"/>

                            <Button Classes="toolbar-btn primary"

                                    HorizontalAlignment="Stretch"

                                    Content="自动编号（未识别文件）"

                                    Command="{Binding BatchAutoNumberCommand}"/>

                            <Button Classes="toolbar-btn"

                                    HorizontalAlignment="Stretch"

                                    Content="插卡重命名"

                                    Command="{Binding InsertCutCommand}"/>

                        </StackPanel>



                        <Border Classes="section-header">

                            <TextBlock Text="缺卡检测"/>

                        </Border>

                        <StackPanel Margin="12,10" Spacing="8">

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">

                                <TextBlock Grid.Column="0"

                                           Text="起始镜号"

                                           VerticalAlignment="Center"

                                           Opacity="0.75"

                                           FontSize="12"/>

                                <NumericUpDown Grid.Column="1"

                                               Minimum="0"

                                               Maximum="999"

                                               Value="{Binding MissingCutFrom}"/>

                            </Grid>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">

                                <TextBlock Grid.Column="0"

                                           Text="结束镜号"

                                           VerticalAlignment="Center"

                                           Opacity="0.75"

                                           FontSize="12"/>

                                <NumericUpDown Grid.Column="1"

                                               Minimum="0"

                                               Maximum="999"

                                               Value="{Binding MissingCutTo}"/>

                            </Grid>

                            <TextBlock Text="0 = 自动（按已识别镜号范围）"

                                       Opacity="0.6"

                                       FontSize="11"/>

                            <Button Classes="toolbar-btn"

                                    HorizontalAlignment="Stretch"

                                    Content="缺卡检测"

                                    Command="{Binding DetectMissingCutsCommand}"/>

                            <Button Classes="toolbar-btn"

                                    HorizontalAlignment="Stretch"

                                    Content="导出缺卡清单"

                                    Command="{Binding ExportMissingCutsCommand}"/>

                        </StackPanel>



                        <Border Classes="section-header">

                            <TextBlock Text="帧序列绑定"/>

                        </Border>

                        <StackPanel Margin="12,10" Spacing="8">

                            <TextBlock Text="{Binding FrameSequenceSummary}"

                                       TextWrapping="Wrap"

                                       Opacity="0.85"

                                       FontSize="12"/>

                            <Button Classes="toolbar-btn"

                                    HorizontalAlignment="Stretch"

                                    Content="帧序列检测"

                                    Command="{Binding DetectFrameSequencesCommand}"/>

                            <Button Classes="toolbar-btn"

                                    HorizontalAlignment="Stretch"

                                    Content="导出帧序列问题"

                                    Command="{Binding ExportFrameSequencesCommand}"/>

                        </StackPanel>



                        <Border Classes="section-header">

                            <TextBlock Text="操作历史"/>

                        </Border>

                        <StackPanel Margin="12,10" Spacing="8">

                            <TextBlock Text="{Binding UndoableCount, StringFormat=还可撤销 {0} 步}"

                                       Opacity="0.85"

                                       FontSize="12"

                                       IsVisible="{Binding HasUndoableOperations}"/>

                            <ListBox MaxHeight="120"

                                     ItemsSource="{Binding OperationHistoryItems}"

                                     ScrollViewer.VerticalScrollBarVisibility="Auto">

                                <ListBox.ItemTemplate>

                                    <DataTemplate>

                                        <TextBlock Text="{Binding Summary}"

                                                   TextWrapping="Wrap"

                                                   FontSize="11"

                                                   Opacity="0.9"/>

                                    </DataTemplate>

                                </ListBox.ItemTemplate>

                            </ListBox>

                            <Button Classes="toolbar-btn"

                                    HorizontalAlignment="Stretch"

                                    Content="撤销上一步"

                                    Command="{Binding UndoCommand}"/>

                        </StackPanel>



                        <Border Classes="section-header">

                            <TextBlock Text="筛选"/>

                        </Border>

                        <StackPanel Margin="12,10" Spacing="8">

                            <TextBox PlaceholderText="版本标签 (v1 / draft / s)"

                                     Text="{Binding VersionTagFilter}"/>

                            <Button Classes="toolbar-btn"

                                    HorizontalAlignment="Stretch"

                                    Content="应用筛选"

                                    Command="{Binding ApplyVersionFilterCommand}"/>

                        </StackPanel>

                    </StackPanel>

                </ScrollViewer>

            </Border>



            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"/>



            <!-- Center: file list -->

            <Border Grid.Column="2" Classes="workspace-panel">

                <Grid RowDefinitions="Auto,*">

                    <Border Grid.Row="0" Classes="panel-title" MinHeight="52">

                        <Grid RowDefinitions="Auto,18">

                            <TextBlock Grid.Row="0" Text="{Binding ShotListTitle}"/>

                            <TextBlock Grid.Row="1"

                                       Text="{Binding ReorderDragHint}"

                                       Foreground="#5B9BD5"

                                       FontSize="11"

                                       VerticalAlignment="Top"

                                       TextTrimming="CharacterEllipsis"/>

                        </Grid>

                    </Border>

                    <Grid Grid.Row="1" RowDefinitions="Auto,*">

                        <Grid x:Name="ShotListHeaderGrid"

                              Grid.Row="0"

                              Background="#484848"

                              Height="32">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="90" MinWidth="48"/>

                                <ColumnDefinition Width="4"/>

                                <ColumnDefinition Width="200" MinWidth="64"/>

                                <ColumnDefinition Width="4"/>

                                <ColumnDefinition Width="200" MinWidth="64"/>

                                <ColumnDefinition Width="4"/>

                                <ColumnDefinition Width="80" MinWidth="48"/>

                                <ColumnDefinition Width="4"/>

                                <ColumnDefinition Width="*" MinWidth="80"/>

                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="卡号" Foreground="#DDDDDD" VerticalAlignment="Center" Margin="8,0"/>

                            <GridSplitter Grid.Column="1"

                                          Classes="shot-list-column-splitter"

                                          Width="4"

                                          ResizeDirection="Columns"/>

                            <TextBlock Grid.Column="2" Text="来源" Foreground="#DDDDDD" VerticalAlignment="Center" Margin="8,0"/>

                            <GridSplitter Grid.Column="3"

                                          Classes="shot-list-column-splitter"

                                          Width="4"

                                          ResizeDirection="Columns"/>

                            <TextBlock Grid.Column="4" Text="目标" Foreground="#DDDDDD" VerticalAlignment="Center" Margin="8,0"/>

                            <GridSplitter Grid.Column="5"

                                          Classes="shot-list-column-splitter"

                                          Width="4"

                                          ResizeDirection="Columns"/>

                            <TextBlock Grid.Column="6" Text="状态" Foreground="#DDDDDD" VerticalAlignment="Center" Margin="8,0"/>

                            <GridSplitter Grid.Column="7"

                                          Classes="shot-list-column-splitter"

                                          Width="4"

                                          ResizeDirection="Columns"/>

                            <TextBlock Grid.Column="8" Text="说明" Foreground="#DDDDDD" VerticalAlignment="Center" Margin="8,0"/>

                        </Grid>

                        <Grid Grid.Row="1">

                        <ListBox x:Name="ShotList"
                                 Classes="shot-list"
                                 DragDrop.AllowDrop="True"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"

                                 ItemsSource="{Binding PreviewItems}"

                                 SelectedItem="{Binding SelectedPreviewRow}"

                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"

                                 ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <ListBox.ItemTemplate>

                                <DataTemplate x:DataType="vm:PreviewRowViewModel">

                                    <Grid MinHeight="32">

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="{Binding #ShotList.((vm:MainWindowViewModel)DataContext).ShotColCutWidth}"/>

                                            <ColumnDefinition Width="{Binding #ShotList.((vm:MainWindowViewModel)DataContext).ShotColSourceWidth}"/>

                                            <ColumnDefinition Width="{Binding #ShotList.((vm:MainWindowViewModel)DataContext).ShotColTargetWidth}"/>

                                            <ColumnDefinition Width="{Binding #ShotList.((vm:MainWindowViewModel)DataContext).ShotColStatusWidth}"/>

                                            <ColumnDefinition Width="*"/>

                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"

                                                   Text="{Binding DisplayCutId}"

                                                   Foreground="#DDDDDD"

                                                   VerticalAlignment="Center"

                                                   Margin="8,4"/>

                                        <TextBlock Grid.Column="1"

                                                   Text="{Binding Source}"

                                                   Foreground="#DDDDDD"

                                                   VerticalAlignment="Center"

                                                   Margin="8,4"

                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="2"

                                                   Text="{Binding Target}"

                                                   Foreground="#DDDDDD"

                                                   VerticalAlignment="Center"

                                                   Margin="8,4"

                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="3"

                                                   Text="{Binding Status}"

                                                   Foreground="#DDDDDD"

                                                   VerticalAlignment="Center"

                                                   Margin="8,4"/>

                                        <TextBlock Grid.Column="4"

                                                   Text="{Binding Message}"

                                                   Foreground="#AAAAAA"

                                                   VerticalAlignment="Center"

                                                   Margin="8,4"

                                                   TextTrimming="CharacterEllipsis"/>

                                    </Grid>

                                </DataTemplate>

                            </ListBox.ItemTemplate>

                        </ListBox>

                        <Canvas x:Name="ReorderOverlay"

                                HorizontalAlignment="Stretch"

                                VerticalAlignment="Stretch"

                                IsHitTestVisible="False">

                            <Border x:Name="ReorderInsertIndicator"

                                    IsVisible="False"

                                    Height="2"

                                    Background="#5B9BD5"/>

                        </Canvas>

                        </Grid>

                    </Grid>

                </Grid>

            </Border>



            <GridSplitter Grid.Column="3" Width="4" ResizeDirection="Columns"/>



            <!-- Right sidebar: preview -->

            <Border Grid.Column="4" Classes="preview-panel" MinWidth="240">

                <Grid RowDefinitions="Auto,Auto,*,Auto">

                    <Border Grid.Row="0" Classes="panel-title">

                        <TextBlock Text="文件预览"/>

                    </Border>

                    <TextBlock Grid.Row="1"

                               Margin="12,8,12,0"

                               Text="{Binding PreviewCaption}"

                               TextWrapping="Wrap"

                               FontSize="12"

                               Opacity="0.8"/>

                    <Border Grid.Row="2"

                            Margin="12,8"

                            Background="#2B2B2B"

                            CornerRadius="2"

                            BorderBrush="#555555"

                            BorderThickness="1">

                        <Image Source="{Binding PreviewImage}"

                               Stretch="Uniform"

                               Margin="4"

                               HorizontalAlignment="Center"

                               VerticalAlignment="Center"/>

                    </Border>

                    <StackPanel Grid.Row="3" Margin="12,0,12,12" Spacing="6">

                        <Border Classes="section-header" Padding="8,4">

                            <TextBlock Text="卡号画廊" FontSize="11"/>

                        </Border>

                        <TextBlock Text="{Binding GalleryHint}"

                                   FontSize="11"

                                   Opacity="0.6"

                                   TextWrapping="Wrap"

                                   IsVisible="{Binding ShowGalleryHint}"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"

                                      VerticalScrollBarVisibility="Disabled"

                                      MaxHeight="110">

                            <ItemsControl ItemsSource="{Binding CutGallery}">

                                <ItemsControl.ItemsPanel>

                                    <ItemsPanelTemplate>

                                        <StackPanel Orientation="Horizontal" Spacing="6"/>

                                    </ItemsPanelTemplate>

                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>

                                    <DataTemplate x:DataType="vm:CutGalleryItemViewModel">

                                        <Button Padding="4"

                                                Background="Transparent"

                                                BorderBrush="#555555"

                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectGalleryCutCommand}"

                                                CommandParameter="{Binding CutId}">

                                            <StackPanel Width="68" Spacing="3">

                                                <Border Background="#2B2B2B"

                                                        BorderBrush="#555555"

                                                        BorderThickness="1"

                                                        Width="64" Height="64">

                                                    <Image Source="{Binding Thumbnail}"

                                                           Stretch="Uniform"

                                                           Margin="2"/>

                                                </Border>

                                                <TextBlock Text="{Binding CutId}"

                                                           FontSize="10"

                                                           HorizontalAlignment="Center"

                                                           TextWrapping="Wrap"

                                                           Opacity="0.85"/>

                                            </StackPanel>

                                        </Button>

                                    </DataTemplate>

                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </ScrollViewer>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>



        <!-- Status bar -->

        <Border Grid.Row="3" Classes="status-bar">

            <StackPanel Spacing="4">

                <ProgressBar Minimum="0"

                             Maximum="{Binding OperationProgressMaximum}"

                             Value="{Binding OperationProgressValue}"

                             Height="4"

                             IsVisible="{Binding ShowOperationProgress}"/>

                <Grid ColumnDefinitions="*,Auto">

                    <TextBlock Grid.Column="0"

                               Text="{Binding StatusMessage}"

                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Grid.Column="1"

                               Margin="16,0,0,0"

                               Text="{Binding MissingCutsSummary}"

                               Foreground="#88BBFF"

                               IsVisible="{Binding MissingCutsSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                </Grid>

            </StackPanel>

        </Border>

    </Grid>

</Window>


